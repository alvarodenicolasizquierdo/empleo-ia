---
import Base from "../../../layouts/Base.astro";
import ScoreBadgeStatic from "../../../components/astro/ScoreBadgeStatic.astro";
import { SCORE_COLORS } from "@/lib/occupationData";
import { loadAllOccupations, occupationSlug, sectorSlug } from "@/data/loadOccupations";
import { t, scoreLabel } from "@/i18n/pages";

export async function getStaticPaths() {
  const { es, enByCno } = loadAllOccupations();
  return es.map((occ) => ({
    params: { slug: occupationSlug(occ) },
    props: { occ, en: enByCno.get(occ.cno)! },
  }));
}

const { occ, en } = Astro.props;
const lang = "en" as const;
const score = occ.vulnerabilidad_ia_score;
const colorIndex = Math.round(Math.min(10, Math.max(0, score)));
const scoreColor = SCORE_COLORS[colorIndex];

const title = `${en.nombre} — AI vulnerability ${score}/10`;
const description = `${en.nombre} (CNO ${occ.cno}): AI vulnerability score ${score}/10, ${occ.empleo.toLocaleString("en-US")} workers, average salary ${occ.salario_medio_eur.toLocaleString("en-US")} €. Sector: ${en.sector}.`;

const occupationJsonLd = {
  "@context": "https://schema.org",
  "@type": "Occupation",
  "name": en.nombre,
  "alternateName": occ.nombre,
  "occupationalCategory": `CNO-11:${occ.cno}`,
  "description": en.justificacion,
  "estimatedSalary": {
    "@type": "MonetaryAmountDistribution",
    "name": "Average annual salary",
    "currency": "EUR",
    "median": occ.salario_medio_eur,
  },
  "occupationLocation": { "@type": "Country", "name": "Spain" },
  "mainEntityOfPage": Astro.url.href,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t(lang, "home"), "item": new URL("/en/", Astro.site).href },
    { "@type": "ListItem", "position": 2, "name": t(lang, "sectors"), "item": new URL("/en/sector/", Astro.site).href },
    { "@type": "ListItem", "position": 3, "name": en.sector, "item": new URL(`/en/sector/${sectorSlug(occ.sector)}`, Astro.site).href },
    { "@type": "ListItem", "position": 4, "name": en.nombre, "item": Astro.url.href },
  ],
};

const wageIndex = occ.empleo * occ.salario_medio_eur * (score / 10);
const wageLabel = wageIndex >= 1e9 ? (wageIndex / 1e9).toFixed(1) + "B €" : (wageIndex / 1e6).toFixed(0) + "M €";

const F = "'DM Sans', sans-serif";
const S = "'Cormorant Garamond', serif";
---

<Base title={title} description={description} jsonLd={[occupationJsonLd, breadcrumbJsonLd]} lang="en" alternatePath={`/ocupacion/${occupationSlug(occ)}`}>
  <div style={`background:#faf8f4;color:#1a1a1a;min-height:100vh;font-family:${F};`}>
    <article style="max-width:900px;margin:0 auto;padding:28px 24px;">

      <nav style="font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#bbb;margin-bottom:6px;">
        <a href="/en/" style="color:#c8633a;text-decoration:none;">{t(lang, "home")}</a>
        <span style="margin:0 4px;">›</span>
        <a href="/en/sector/" style="color:#c8633a;text-decoration:none;">{t(lang, "sectors")}</a>
        <span style="margin:0 4px;">›</span>
        <a href={`/en/sector/${sectorSlug(occ.sector)}`} style="color:#c8633a;text-decoration:none;">{en.sector}</a>
        <span style="margin:0 4px;">›</span>
        <span>CNO {occ.cno}</span>
        <span style="margin:0 10px;color:#ddd;">·</span>
        <a href={`/ocupacion/${occupationSlug(occ)}`} style="color:#aaa;text-decoration:none;">🌐 Español</a>
      </nav>

      <h1 style={`font-size:clamp(26px,3.5vw,44px);font-family:${S};font-weight:600;margin:0 0 4px;line-height:1.08;color:#1a1a1a;`}>
        {en.nombre}
      </h1>
      <p style="font-size:14px;color:#888;margin:0 0 20px;font-style:italic;">
        {occ.nombre}
      </p>

      <div style="display:flex;align-items:center;gap:14px;margin-bottom:24px;">
        <ScoreBadgeStatic score={score} size="lg" />
        <div>
          <div style={`font-size:15px;font-weight:600;color:${scoreColor};`}>
            {t(lang, "exposureLabel")}: {scoreLabel(lang, score)}
          </div>
          <div style="font-size:12px;color:#888;">{score.toFixed(1)} / 10</div>
          <div style="font-size:10px;color:#b08050;margin-top:2px;font-style:italic;">{t(lang, "theoreticalCaveat")}</div>
        </div>
      </div>

      <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;">
        <div style="padding:14px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">{t(lang, "employees")}</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>
            {occ.empleo >= 1e6 ? (occ.empleo / 1e6).toFixed(1) + "M" : occ.empleo >= 1e3 ? Math.round(occ.empleo / 1e3) + "K" : occ.empleo.toLocaleString("en-US")}
          </div>
        </div>
        <div style="padding:14px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">{t(lang, "avgSalary")}</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#1a1a1a;`}>
            {occ.salario_medio_eur.toLocaleString("en-US")} €
          </div>
        </div>
        <div style="padding:14px 16px;background:#f0ece4;border-radius:6px;flex:1 1 150px;min-width:140px;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1.3px;color:#aaa;margin-bottom:4px;">{t(lang, "wageIndex")}</div>
          <div style={`font-size:22px;font-weight:700;font-family:${S};line-height:1.1;color:#c8633a;`}>
            {wageLabel}
          </div>
          <div style="font-size:10px;color:#c8633a;margin-top:2px;font-weight:600;">{t(lang, "wageIndexFormula")}</div>
        </div>
      </div>

      {occ.rescore_D != null && (
        <div style="margin-bottom:20px;padding:16px;background:#f0ece4;border-radius:8px;border:1px solid #e0dcd4;">
          <div style="font-size:9px;text-transform:uppercase;letter-spacing:1px;color:#999;margin-bottom:12px;font-weight:600;">
            {t(lang, "subComponents")}
          </div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            {[
              { key: "D", label: t(lang, "displacement"), value: occ.rescore_D!, color: "#b04232" },
              { key: "C", label: t(lang, "aiCapability"), value: occ.rescore_C!, color: "#d4a85a" },
              { key: "F", label: t(lang, "adoptionFriction"), value: occ.rescore_F!, color: "#3a7d9e" },
              { key: "R", label: t(lang, "regulatoryProtection"), value: occ.rescore_R!, color: "#5494ab" },
            ].map((b) => (
              <div style="display:flex;align-items:center;gap:10px;">
                <div style={`width:14px;font-size:12px;font-weight:700;color:${b.color};text-align:center;flex-shrink:0;`}>{b.key}</div>
                <div style="flex:1;min-width:0;">
                  <div style="display:flex;justify-content:space-between;margin-bottom:2px;">
                    <span style="font-size:10px;color:#666;">{b.label}</span>
                    <span style={`font-size:11px;font-weight:700;color:#1a1a1a;font-family:${S};`}>{b.value.toFixed(1)}</span>
                  </div>
                  <div style="height:6px;background:#e0dcd4;border-radius:3px;overflow:hidden;">
                    <div style={`height:100%;width:${(b.value / 10) * 100}%;background:${b.color};border-radius:3px;`} />
                  </div>
                </div>
              </div>
            ))}
          </div>
          {occ.rescore_formula && (
            <div style="margin-top:10px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:6px;">
              <span style="font-size:10px;color:#888;">
                {t(lang, "formula")}: <code style="font-size:10px;background:#e8e4dc;padding:1px 5px;border-radius:3px;">{occ.rescore_formula}</code>
              </span>
              {occ.score_v9 != null && (
                <span style="font-size:10px;color:#888;font-weight:600;">
                  {t(lang, "rescored")}: {occ.score_v9.toFixed(1)} → {score.toFixed(1)}
                </span>
              )}
            </div>
          )}
        </div>
      )}

      <div style="margin-bottom:16px;">
        <div style="font-size:9px;text-transform:uppercase;letter-spacing:1px;color:#999;margin-bottom:6px;">{t(lang, "automationVector")}</div>
        <div style={`font-size:13px;color:#444;line-height:1.5;padding:10px;background:#f0ece4;border-radius:5px;border-left:3px solid ${scoreColor};`}>
          {en.justificacion}
        </div>
      </div>

      <div style="margin-bottom:16px;">
        <div style="font-size:9px;text-transform:uppercase;letter-spacing:1px;color:#999;margin-bottom:6px;">{t(lang, "automationVectorEn")}</div>
        <div style="font-size:13px;color:#666;line-height:1.5;padding:10px;background:#f0ece4;border-radius:5px;">
          {occ.justificacion}
        </div>
      </div>

      <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:16px;">
        <span style="padding:4px 12px;border-radius:16px;font-size:11px;font-weight:600;background:#f0ece4;color:#666;border:1px solid #e0dcd4;">
          {en.tipo_impacto}
        </span>
        <span style={`padding:4px 12px;border-radius:16px;font-size:11px;font-weight:600;background:${scoreColor}18;color:${scoreColor};border:1px solid ${scoreColor}33;`}>
          EU AI Act: {en.eu_ai_act}
        </span>
        {occ.employment_confidence && (
          <span style={`padding:4px 12px;border-radius:16px;font-size:11px;font-weight:600;background:${occ.employment_confidence === "A+" ? "#3a7d9e22" : occ.employment_confidence === "A" ? "#5494ab22" : "#d4a85a22"};color:${occ.employment_confidence === "A+" ? "#2b6a8e" : occ.employment_confidence === "A" ? "#3a7d9e" : "#b08050"};`}>
            {t(lang, "employmentConfidence")}: {occ.employment_confidence}
          </span>
        )}
      </div>

      <div style="margin-top:24px;padding-top:16px;border-top:1px solid #e8e4dc;">
        <a href={`/en/?cno=${occ.cno}`} style={`display:inline-flex;align-items:center;gap:6px;padding:7px 14px;font-size:11px;font-weight:600;font-family:${F};background:#1a1a1a;color:#faf8f4;border-radius:5;text-decoration:none;letter-spacing:0.3px;`}>
          {t(lang, "seeInDashboard")}
        </a>
      </div>

      <div style="margin-top:20px;font-size:10px;color:#bbb;line-height:1.65;">
        <strong style="color:#999;">{t(lang, "sourceLabel")}</strong> {t(lang, "sourceLine")}
      </div>
    </article>
  </div>
</Base>
